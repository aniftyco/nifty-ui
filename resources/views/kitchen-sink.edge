<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nifty UI :: Kitchen Sink</title>
  @entryPointStyles('app')
  @entryPointScripts('app')
</head>
<body>
  <h1 class="flex justify-center text-4xl font-semibold leading-relaxed">Nifty UI :: Kitchen Sink</h1>
  <hr />
  <main class="m-4">
    {{--  Accordion  --}}
    <div class="flex flex-col my-2 w-5/12">
      <h2 class='text-2xl font-bold'>Accordion</h2>
      <div class="w-5/6 my-4">
        @ui.accordion()
          @ui.accordion.item({ title: 'Check me out!' })
            I hold a message, good or bad I exist!
          @end

          @ui.accordion.item({ title: 'Keep adding items!' })
            Keep adding items to make this list as long or short as you want!
          @end
        @end
      </div>
    </div>
    {{--  Alerts  --}}
    <div class="flex flex-col">

      <h2 class='text-2xl font-bold'>Alert</h2>

        @ui.alert({ variant: 'success'})
          <h5 class='font-bold underline'>Thou hath reached a bitter Success!</h5>
          <p>Fetch the scribe! Might he record this most joyous of days!</p>
        @end

        @ui.alert({ variant: 'default'})
          <h5 class='font-bold underline'>A Default message for you My Lord!</h5>
          <p>Nifty-UI has made progress on the western banks of the Mississippi!!</p>
        @end

        @ui.alert({ variant: 'info'})
          <h5 class='font-bold underline'>Information suggests the filthy Bard has arrived.</h5>
          <p>This can only mean a Witcher is close by.</p>
        @end

        @ui.alert({ variant: 'warning'})
          <h5 class='font-bold underline'>WARNING! Ye Adventure's:</h5>
          <p>Dragons lair beyond the ridge, use southern passage.</p>
        @end

        @ui.alert({ variant: 'error'})
          <h5 class='font-bold underline'>You made a vital ERROR, way to go.</h5>
          <p>If you can read this, you can't read a compass. Good luck.</p>
        @end
    </div>
    {{-- Badge --}}

    <h2 class='text-2xl font-bold'>Badges</h2>
    <div class="flex space-x-2">
      @ui.badge({ variant: 'default'})
        <p>Default</p>
      @end
      @ui.badge({ variant: 'solid'})
        <p>Solid</p>
      @end

      @ui.badge({ variant: 'outline'})
        <p>outline</p>
      @end
    </div>
    <div class="flex space-x-2 mt-2">
      @ui.badge({ size: 'sm' })
        <p>Small Default</p>
      @end
      @ui.badge({ variant: 'solid', size: 'sm' })
        <p>small solid</p>
      @end
      @ui.badge({ variant:'outline', size: 'sm' })
        <p>small outline</p>
      @end
    </div>
    <div class="flex space-x-2 mt-2">
      @ui.badge({ size: 'lg' })
        <p>Large Default</p>
      @end
      @ui.badge({ variant: 'solid', size: 'lg' })
        <p>Large solid</p>
      @end
      @ui.badge({ variant:'outline', size: 'lg' })
        <p>Large outline</p>
      @end
    </div>
    <div class="flex space-x-2 mt-2">
      @ui.badge({ size: 'xl' })
        <p>Extra-Large Default</p>
      @end
      @ui.badge({ variant: 'solid', size: 'xl' })
        <p>Extra-Large solid</p>
      @end
      @ui.badge({ variant:'outline', size: 'xl' })
        <p>Extra-Large outline</p>
      @end
    </div>
    <div class="flex space-x-2 mt-2">
      @ui.badge({ variant:'success', size: 'default' })
        <p>Success!</p>
      @end
      @ui.badge({ variant:'warning', size: 'default' })
        <p>Warning!</p>
      @end
      @ui.badge({ variant:'danger', size: 'default' })
        <p>Danger!</p>
      @end
    </div>
    {{--  Buttons  --}}

    <h2 class='text-2xl font-bold'>Buttons</h2>
    <div class="flex flex-col gap-2">
      <div class="flex space-x-2">
        @ui.button({ variant:'default', size: 'sm' })
          <p>Default Small</p>
        @end
        @ui.button({ variant:'solid', size: 'sm' })
          <p>Solid Small</p>
        @end
        @ui.button({ variant:'outline', size: 'sm' })
          <p>Outline Small</p>
        @end
        @ui.button({ variant:'ghost', size: 'sm' })
          <p>Ghost Small</p>
        @end
        @ui.button({ variant:'link', size: 'sm' })
          <p>Link Small</p>
        @end
      </div>
      <div class="flex space-x-2">
        @ui.button({ variant:'default', size: 'default' })
          <p>Default Default</p>
        @end
        @ui.button({ variant:'solid', size: 'default' })
          <p>Solid Default</p>
        @end
        @ui.button({ variant:'outline', size: 'default' })
          <p>Outline Default</p>
        @end
        @ui.button({ variant:'ghost', size: 'default' })
          <p>Ghost Default</p>
        @end
        @ui.button({ variant:'link', size: 'default' })
          <p>Link Default</p>
        @end
      </div>
      <div class="flex space-x-2">
        @ui.button({ variant:'default', size: 'lg'})
          <p>Default Large</p>
        @end
        @ui.button({ variant:'solid', size: 'lg' })
          <p>Solid Large</p>
        @end
        @ui.button({ variant:'outline', size: 'lg' })
          <p>Outline Large</p>
        @end
        @ui.button({ variant:'ghost', size: 'lg' })
          <p>Ghost Large</p>
        @end
        @ui.button({ variant:'link', size: 'lg' })
          <p>Link Large</p>
        @end
      </div>
      <div class="flex space-x-2">
        @ui.button({ variant:'default', size: 'xl'})
          <p>Default X-Large</p>
        @end
        @ui.button({ variant:'solid', size: 'xl' })
          <p>Solid X-Large</p>
        @end
        @ui.button({ variant:'outline', size: 'xl' })
          <p>Outline X-Large</p>
        @end
        @ui.button({ variant:'ghost', size: 'xl' })
          <p>Ghost X-Large</p>
        @end
        @ui.button({ variant:'link', size: 'xl' })
          <p>Link X-Large</p>
        @end
      </div>
      <h3 class="text-lg font-semibold">Custom Button</h3>
      <div class="flex space-x-2">
        @ui.button({ variant:'custom', size: 'default', className: 'bg-violet-600 text-violet-50 underline border border-violet-100 shadow-inner hover:bg-violet-800/80'})
          <p>Custom Button!</p>
        @end
      </div>

      {{--  Checkbox  --}}

      <h2 class='text-2xl font-bold'>Checkboxes</h2>
      <div class="flex gap-2">
        @ui.checkbox({ size: 'sm'})
          @ui.label({ size: 'sm'})
            Small Checkbox
          @end
        @end
        @ui.checkbox({ size: 'default'})
          @ui.label({ size: 'default'})
            Default Checkbox
          @end
        @end
        @ui.checkbox({ size: 'lg'})
          @ui.label({ size: 'lg'})
            Large Checkbox
          @end
        @end
    </div>

    {{--  Table  --}}
    <h2 class='text-2xl font-bold'>Table</h2>
      <div class="flex gap-2 w-1/2">
        @ui.table()
        @end
    </div>

    {{--  Textarea  --}}
    <h2 class='text-2xl font-bold'>Textarea</h2>
      <div class="flex gap-2 w-1/2">
        @ui.textarea()
        @end
    </div>


  </main>
</body>
