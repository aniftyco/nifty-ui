@set('className', clsx([
  'relative w-full mx-auto overflow-hidden text-sm font-normal border divide-y rounded-md',
  'bg-white border-gray-200 divide-gray-200'
], className))

<div x-data="{
        activeAccordion: '',
        setActiveAccordion(id) {
            this.activeAccordion = (this.activeAccordion == id) ? '' : id
        }
    }" class="{{ className }}">
    {{{ await $slots.main() }}}
</div>
